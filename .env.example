# =============================================================
# EMN Records Musician Directory & Credit Builder — 環境変数
# 実値は .env.local（ローカル）/ Vercel環境変数（本番）に設定する。
# このファイルには実値を書かないこと。
# =============================================================

# --- Public（ブラウザに公開される。秘密情報を入れない） ---

# 公開URL。本番は https://musicians.emnrecords.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase（未設定の場合はmockデータで動作する）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# 旧来のキー名を使う場合（PUBLISHABLE_KEYが優先される）
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-only（絶対に NEXT_PUBLIC を付けない） ---

# Supabase secret (service_role) key。
# members_only素材の取得・アップロードmetadata保存に必要。
SUPABASE_SECRET_KEY=

# WordPress REST API アップロード（ConoHa WING上のWordPress）
WORDPRESS_BASE_URL=
WORDPRESS_UPLOAD_USERNAME=
WORDPRESS_APPLICATION_PASSWORD=

# 立ち絵ダウンロードページの共通パスワード。
# 推奨: sha256 hexハッシュを設定（生成方法はREADME参照）
MEMBER_DOWNLOAD_PASSWORD_HASH=
# やむを得ない場合のみ平文（本番ではhashへ移行すること）
# MEMBER_DOWNLOAD_PASSWORD=

# 立ち絵アップロードページのパスワード（download用とは必ず別にする）
ASSET_UPLOAD_PASSWORD_HASH=
# ASSET_UPLOAD_PASSWORD=

# 任意: アクセスcookie署名用シークレット（未設定時はパスワードから導出）
ACCESS_TOKEN_SECRET=
