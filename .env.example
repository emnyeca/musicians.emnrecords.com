# 公開URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 公開用Supabase接続情報。publishable keyの読み取り範囲はRLSで制限する。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# サーバー専用。NEXT_PUBLICを付けず、Discord Botにも渡さない。
SUPABASE_SECRET_KEY=

# 暫定的な運営者専用管理画面の認証。
ADMIN_PASSWORD_HASH=
# ADMIN_PASSWORD=
ACCESS_TOKEN_SECRET=

# 今後追加するDiscord入力処理。Botは最小権限の受付API認証情報を使い、
# SUPABASE_SECRET_KEYをBotプロセスへ設定しない。
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_MEMBER_ROLE_ID=
DISCORD_OPERATOR_ROLE_ID=
DISCORD_AUDIT_CHANNEL_ID=
INTAKE_API_URL=
INTAKE_API_SECRET=
